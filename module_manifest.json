{
  "module_key": "@istari:openfoam",
  "module_name": "@istari:openfoam",
  "module_display_name": "OpenFOAM v13 Solver",
  "module_type": "function",
  "module_version": "0.2.0",
  "module_checksum": "hash",
  "internal": true,
  "operating_systems": ["Ubuntu 22.04", "Ubuntu 24.04", "RHEL 9"],
  "agent_version": ">=2.0.0",
  "tool_key": "openfoamv13",
  "tool_versions": ["13"],
  "tool_display_name": "OpenFOAM v13",
  "additional_configuration_required": false,
  "authors": [
    {
      "name": "Ross Billings",
      "email": "rbillings@istaridigital.com"
    }
  ],
  "dependencies": [
    {
      "name": "openfoam",
      "version": "13",
      "tool_type": "auxiliary_tool",
      "display_name": "OpenFOAM v13",
      "reason": "CFD solver runtime",
      "url": "https://openfoam.org/download/"
    }
  ],
  "dev_dependencies": [
    {
      "name": "pytest",
      "version": ">=7.0.0",
      "tool_type": "auxiliary_tool",
      "display_name": "pytest",
      "reason": "Unit and integration test runner"
    }
  ],
  "scripts": [
    {
      "operating_systems": ["Ubuntu 22.04", "Ubuntu 24.04", "RHEL 9"],
      "install": "scripts/linux/install.sh",
      "test_unit": "scripts/linux/test_unit.sh",
      "clean": "scripts/linux/clean.sh"
    }
  ],
  "functions": {
    "@istari:run_foam": [
      {
        "display_name": "Run OpenFOAM Simulation",
        "entrypoint": "openfoam_module",
        "run_command": "{entrypoint} run_foam --input-file {input_file} --output-file {output_file} --temp-dir {temp_dir} --config-path {config_path}",
        "operating_systems": ["Ubuntu 22.04", "Ubuntu 24.04", "RHEL 9"],
        "tool_versions": ["13"],
        "function_schema": {
          "inputs": {
            "foam_case": {
              "type": "user_model",
              "validation_types": ["@extension:zip"],
              "display_name": "OpenFOAM Case (.foam.zip)",
              "optional": false
            },
            "override_end_time": {
              "type": "parameter",
              "validation_types": ["@number"],
              "display_name": "Override endTime (seconds)",
              "optional": true
            },
            "override_np": {
              "type": "parameter",
              "validation_types": ["@number"],
              "display_name": "Override parallel core count",
              "optional": true
            }
          },
          "outputs": [
            {
              "name": "solved_case",
              "type": "file",
              "required": true,
              "display_name": "Solved Case Archive (.foam.zip)",
              "upload_as": "model",
              "version_of": "foam_case"
            },
            {
              "name": "run_log",
              "type": "file",
              "required": true,
              "display_name": "Solver Log (foamRun.log)",
              "upload_as": "artifact"
            },
            {
              "name": "convergence_report",
              "type": "file",
              "required": false,
              "display_name": "Convergence Report (JSON)",
              "upload_as": "artifact"
            },
            {
              "name": "inputs",
              "type": "file",
              "required": false,
              "display_name": "Simulation Inputs — post-override (inputs.json)",
              "upload_as": "artifact"
            }
          ]
        }
      }
    ],
    "@istari:inspect_foam": [
      {
        "display_name": "Inspect OpenFOAM Case",
        "entrypoint": "openfoam_module",
        "run_command": "{entrypoint} inspect_foam --input-file {input_file} --output-file {output_file} --temp-dir {temp_dir} --config-path {config_path}",
        "operating_systems": ["Ubuntu 22.04", "Ubuntu 24.04", "RHEL 9"],
        "tool_versions": ["13"],
        "function_schema": {
          "inputs": {
            "foam_case": {
              "type": "user_model",
              "validation_types": ["@extension:zip"],
              "display_name": "OpenFOAM Case (.foam.zip)",
              "optional": false
            },
            "run_checkmesh": {
              "type": "parameter",
              "validation_types": ["@boolean"],
              "display_name": "Run checkMesh utility",
              "optional": true
            }
          },
          "outputs": [
            {
              "name": "inspection_report",
              "type": "file",
              "required": true,
              "display_name": "Inspection Report (JSON)",
              "upload_as": "artifact"
            },
            {
              "name": "inputs",
              "type": "file",
              "required": false,
              "display_name": "Simulation Inputs (inputs.json)",
              "upload_as": "artifact"
            }
          ]
        }
      }
    ],
    "@istari:update_foam": [
      {
        "display_name": "Update OpenFOAM Parameters",
        "entrypoint": "openfoam_module",
        "run_command": "{entrypoint} update_foam --input-file {input_file} --output-file {output_file} --temp-dir {temp_dir} --config-path {config_path}",
        "operating_systems": ["Ubuntu 22.04", "Ubuntu 24.04", "RHEL 9"],
        "tool_versions": ["13"],
        "function_schema": {
          "inputs": {
            "foam_case": {
              "type": "user_model",
              "validation_types": ["@extension:zip"],
              "display_name": "OpenFOAM Case (.foam.zip)",
              "optional": false
            },
            "input_json": {
              "type": "parameter",
              "validation_types": ["@string"],
              "display_name": "Parameter patches (JSON array of {file, key, value})",
              "optional": true
            },
            "output_case_name": {
              "type": "parameter",
              "validation_types": ["@string"],
              "display_name": "New case name (optional rename)",
              "optional": true
            }
          },
          "outputs": [
            {
              "name": "patched_case",
              "type": "file",
              "required": true,
              "display_name": "Patched Case Archive (.foam.zip)",
              "upload_as": "model",
              "version_of": "foam_case"
            },
            {
              "name": "patch_report",
              "type": "file",
              "required": true,
              "display_name": "Patch Report (JSON)",
              "upload_as": "artifact"
            }
          ]
        }
      }
    ]
  }
}
