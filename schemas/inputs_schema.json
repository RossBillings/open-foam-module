{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:istari:openfoam:inputs:v1",
  "title": "OpenFOAM Case Inputs",
  "description": "Canonical simulation parameter manifest extracted from a .foam.zip case. Generated by inspect_foam and run_foam; consumed by patch_foam.",
  "type": "object",
  "required": ["schema_version", "case_name", "solver", "time"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "case_name":      { "type": "string" },
    "solver": {
      "type": "object",
      "required": ["application", "module"],
      "properties": {
        "application": { "type": ["string", "null"] },
        "module":      { "type": ["string", "null"] },
        "parallel":    { "type": "boolean", "default": false },
        "np":          { "type": "integer", "minimum": 1, "default": 1 }
      }
    },
    "time": {
      "type": "object",
      "required": ["startTime", "endTime", "deltaT", "writeInterval"],
      "properties": {
        "startTime":     { "type": "number" },
        "endTime":       { "type": "number" },
        "deltaT":        { "type": "number", "exclusiveMinimum": 0 },
        "writeInterval": { "type": "number", "exclusiveMinimum": 0 },
        "writeControl":  { "type": ["string", "null"] },
        "maxCo":         { "type": ["number", "null"] }
      }
    },
    "transport": {
      "type": "object",
      "properties": {
        "model": { "type": ["string", "null"] },
        "nu":    { "type": ["number", "null"] }
      }
    },
    "turbulence": {
      "type": "object",
      "properties": {
        "simulationType": { "type": ["string", "null"] },
        "model":          { "type": ["string", "null"] }
      }
    },
    "boundary_conditions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "properties": {
            "type":  { "type": "string" },
            "value": { "type": ["string", "number", "array", "null"] }
          }
        }
      }
    },
    "mesh": {
      "type": "object",
      "properties": {
        "generator":  { "type": ["string", "null"], "enum": ["blockMesh", "snappyHexMesh", "foamMergeCase", null] },
        "cell_count": { "type": ["integer", "null"] }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "generated_by": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "foam_version": { "type": "string" },
        "source_zip":   { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
